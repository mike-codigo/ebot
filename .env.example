# ================================================
# VARIÁVEIS DE AMBIENTE - Ê-BOT / Ê-SISTEMAS
# ================================================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env no git!

# ================================================
# API GROQ (OBRIGATÓRIO)
# ================================================
# Chave da API do Groq para o chat de IA
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# ================================================
# WHATSAPP (OPCIONAL)
# ================================================
# Número do WhatsApp para contato (formato: 5546999999999)
WHATSAPP_NUMBER=5546999130505

# ================================================
# ANALYTICS (OPCIONAL)
# ================================================
# ID do Google Analytics 4 (formato: G-XXXXXXXXXX)
# ANALYTICS_ID=

# ================================================
# CONFIGURAÇÕES DO SITE
# ================================================
# Nome da empresa
SITE_NAME=Ê-Sistemas

# URL base do site (sem trailing slash)
SITE_URL=https://esistemas.dev.br

# ================================================
# INTEGRAÇÕES
# ================================================
# Email para contato
CONTACT_EMAIL=comercial.ebot@esistemas.dev.br

# Endereço da empresa
COMPANY_ADDRESS=R. Pedro Alvares Cabral, 905 - Centro Norte, Dois Vizinhos - PR, 85660-000

# CNPJ
COMPANY_CNPJ=53.695.158/0001-90
